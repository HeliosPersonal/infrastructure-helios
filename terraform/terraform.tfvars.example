# ====================================================================================
# TERRAFORM VARIABLES EXAMPLE
# ====================================================================================
# Copy this file to terraform.tfvars and terraform.secret.tfvars
# Fill in your actual values
# ====================================================================================

# ====================================================================================
# terraform.tfvars (can be committed to git)
# ====================================================================================

# Domain Configuration
base_domain        = "example.com"
internal_domain    = "helios"
keycloak_subdomain = "keycloak"

# PostgreSQL (shared instance)
pg_storage_size  = "100Gi"
pg_storage_class = "local-path"

# RabbitMQ (shared instance)
rabbit_persistence_size = "30Gi"

# Redis (shared instance)
redis_storage_size  = "15Gi"
redis_storage_class = "local-path"
redis_insight_enabled = true

# Typesense (shared instance)
typesense_storage_size = "50Gi"

# Keycloak
keycloak_admin_user = "admin"

# Ollama
ollama_enabled            = true
ollama_helm_chart_version = "1.54.0"
ollama_image_tag          = "0.20.3"
ollama_models             = ["qwen2.5:7b"]
ollama_storage_size       = "40Gi"
ollama_memory_request     = "4Gi"
ollama_memory_limit       = "24Gi"
ollama_cpu_request        = "500m"
ollama_cpu_limit          = "4000m"

# Headlamp (K8s Dashboard)
headlamp_enabled            = true
headlamp_helm_chart_version = "0.39.0"

# Headlamp OIDC (Keycloak SSO)
headlamp_oidc_realm     = "master"
headlamp_oidc_client_id = "headlamp"
headlamp_oidc_scopes    = "openid,profile,email,groups"

# ====================================================================================
# terraform.secret.tfvars (DO NOT commit to git!)
# ====================================================================================


# Cloudflare Tunnel
# (see docs/CLOUDFLARE_TUNNEL.md for setup instructions)
# cloudflare_tunnel_token = "eyJhIjoiABC..."   # from Zero Trust dashboard
# cloudflared_enabled     = true
# cloudflared_image_tag   = "2025.4.0"

# Shared Infrastructure Passwords
# pg_password       = "your-postgres-password"
# rabbit_password   = "your-rabbitmq-password"
# redis_password    = "your-redis-password"
# typesense_api_key = "your-typesense-api-key"

# Keycloak
# keycloak_admin_password    = "your-keycloak-admin-password"
# keycloak_postgres_password = "your-keycloak-db-password"

# Headlamp OIDC client secret (from Keycloak client credentials tab)
# headlamp_oidc_client_secret = "your-headlamp-oidc-client-secret"

# Grafana Cloud (get these from your Grafana Cloud dashboard)
# grafana_cloud_api_token       = "your-grafana-cloud-token"
# grafana_cloud_prometheus_url  = "https://prometheus-prod-XX-XX.grafana.net"
# grafana_cloud_prometheus_user = "123456"
# grafana_cloud_loki_url        = "https://logs-prod-XX.grafana.net"
# grafana_cloud_loki_user       = "123456"
# grafana_cloud_tempo_url       = "https://tempo-prod-XX.grafana.net:443"
# grafana_cloud_tempo_user      = "123456"
