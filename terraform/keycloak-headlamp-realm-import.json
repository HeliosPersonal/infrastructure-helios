{
  "clients": [
    {
      "clientId": "headlamp",
      "name": "Headlamp K8s Dashboard",
      "description": "OIDC client for Headlamp Kubernetes Dashboard (k8s.devoverflow.org)",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "https://k8s.devoverflow.org/*"
      ],
      "webOrigins": [
        "https://k8s.devoverflow.org"
      ],
      "attributes": {
        "post.logout.redirect.uris": "https://k8s.devoverflow.org/*",
        "access.token.lifespan": "3600",
        "use.refresh.tokens": "true"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "jsonType.label": "String"
          }
        },
        {
          "name": "audience-headlamp",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "headlamp",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ],
  "groups": [
    {
      "name": "headlamp-admins",
      "path": "/headlamp-admins",
      "subGroups": [],
      "attributes": {},
      "realmRoles": [],
      "clientRoles": {}
    }
  ]
}
